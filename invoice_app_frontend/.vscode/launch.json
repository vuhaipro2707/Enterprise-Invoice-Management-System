{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Android Emulator",
      "request": "launch",
      "type": "dart",
      "deviceId": "emulator-5554",
      "env": {
        "JAVA_HOME": "/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home"
      }
    },
    {
      "name": "Chrome Web",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome"
    },
  ],
  "compounds": [
    {
      "name": "Run All Devices",
      "configurations": ["Android Emulator", "Chrome Web"]
    }
  ]
}